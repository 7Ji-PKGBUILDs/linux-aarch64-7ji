pkgname = linux-aarch64-7ji
	pkgdesc = The Linux Kernel and module - almost mainline but with 7Ji's patches, for Amlogic, Rockchip and virt
	depends = coreutils
	depends = initramfs
	depends = kmod
	optdepends = uboot-legacy-initrd-hooks: to generate uboot legacy initrd images
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = linux-firmware-amlogic-ophub: complete firmware set for devices with Amlogic SoCs
	optdepends = wireless-regdb: to set the correct wireless channels of your country

pkgname = linux-aarch64-7ji-headers
	pkgdesc = Header files and scripts for building modules for linux kernel - almost mainline but with 7Ji's patches, for Amlogic, Rockchip and virt
	depends = pahole
